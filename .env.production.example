# OrdoStack production environment template.
# Copy to .env.production and fill values on the server.
# Do not commit .env.production.

ORDOSTACK_ENV=production

# backend-api
DATA_STORE=mysql
DB_HOST=
DB_PORT=3306
DB_NAME=ordostack
DB_USER=
DB_PASSWORD=
SCHEDULER_SERVICE_URL=http://scheduler-service:8100
ML_SERVICE_URL=http://ml-service:8200
AUTH_TOKEN_SECRET=

# web-dashboard
VITE_API_BASE_URL=https://your-domain.example/api

# ml-service
DURATION_MODEL_PATH=

# Optional future ClearML integration. Leave blank until ClearML is intentionally enabled.
CLEARML_API_ACCESS_KEY=
CLEARML_API_SECRET_KEY=
CLEARML_API_HOST=
CLEARML_WEB_HOST=
CLEARML_FILES_HOST=
