# OrdoStack local defaults.
# Do not commit a real .env file.

ORDOSTACK_ENV=local

# backend-api
DATA_STORE=memory
DB_HOST=mysql
DB_PORT=3306
DB_NAME=ordostack
DB_USER=root
DB_PASSWORD=
SCHEDULER_SERVICE_URL=http://localhost:8100
ML_SERVICE_URL=http://localhost:8200
AUTH_TOKEN_SECRET=
AUTH_TOKEN_TTL_MINUTES=10080
AUTH_LOGIN_MAX_FAILURES=5
AUTH_LOGIN_WINDOW_SECONDS=300
AUTH_LOGIN_LOCKOUT_SECONDS=300
AUTH_PASSWORD_MIN_LENGTH=12

# web-dashboard
VITE_API_BASE_URL=http://localhost:8000/api

# ml-service
DURATION_MODEL_PATH=

# Optional future ClearML integration. Leave blank until ClearML is intentionally enabled.
CLEARML_API_ACCESS_KEY=
CLEARML_API_SECRET_KEY=
CLEARML_API_HOST=
CLEARML_WEB_HOST=
CLEARML_FILES_HOST=
